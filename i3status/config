order += "memory"
order += "volume master"
order += "battery 0"
order += "time"

memory {
    format = "RAM %used"
    threshold_degraded = "10%"
}

volume master {
    format = "♪ %volume"
    format_muted = "♪ muted"
    device = "default"
    mixer = "Master"
}

battery 0 {
        format = "%status %percentage"
        format_down = "No battery"
        status_chr = "CHR"
        status_bat = "BAT"
        status_unk = "UNK"
        status_full = "FULL"
        path = "/sys/class/power_supply/BAT%d/uevent"
        low_threshold = 10
        last_full_capacity = true
}

time {
	format = "%Y-%m-%d %H:%M"
}

